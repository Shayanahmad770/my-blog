run = "gunicorn --bind 0.0.0.0:8080 app:app"
entrypoint = "app.py"

[env]
UPLOAD_FOLDER = "/home/runner/${REPL_SLUG}/static/images"

[packager]
language = "python3"

[packager.features]
packageSearch = true
guessImports = true

[languages.python3]
pattern = "**/*.py"

[languages.python3.languageServer]
start = "pylsp"

[nix]
channel = "stable-22_11"

run = "bash start.sh"
entrypoint = "app.py"
# ... rest remains the same